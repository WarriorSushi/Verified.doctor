# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - NEVER COMMIT SECRETS
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase local development
supabase/.branches
supabase/.temp
supabase/.env
supabase/secrets.toml
supabase/seed.sql

# Database dumps - may contain PII
*.dump
*.sql.gz
*.backup

# IDE and editor configs
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# Credentials and secrets - CRITICAL
*.key
*.pem
*.p12
*.pfx
credentials.json
service-account*.json
*-credentials.json
*secret*.json
!package*.json

# Claude/AI files (optional, remove if you want to track)
CLAUDE.md
nul
